---
layout: layouts/base.njk
title: My Other Sites
description: Articles from Text Lab, Variable Fonts, and Text Effects
permalink: /my-other-sites/
---
<section class="page-header">
  <h1 class="page-heading">My Other Sites</h1>
  <p class="page-heading-subtitle">Articles from Text Lab, Variable Fonts &amp; Text Effects</p>
</section>

<section class="section section-border">
  <ul class="article-list external-list">
    {% for item in externalFeeds %}
    <li class="article-list-item external-item">
      <a href="{{ item.url }}" target="_blank" rel="noopener">
        <img class="card-img" src="/assets/images/placeholder-card.svg" alt="" width="440" height="280" />
      </a>
      <div class="card-content">
        <p class="card-meta">
          <a href="{{ item.sourceUrl }}" class="source-link">{{ item.source }}</a>
          {% if item.date %} &mdash; <time>{{ item.date | dateFromString }}</time>{% endif %}
        </p>
        <h3 class="card-heading">
          <a href="{{ item.url }}" class="card-link" target="_blank" rel="noopener">{{ item.title }}</a>
        </h3>
        {% if item.summary %}<p class="card-summary">{{ item.summary | striptags | truncate(160) }}</p>{% endif %}
      </div>
    </li>
    {% endfor %}
  </ul>
</section>
