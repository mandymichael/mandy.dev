---
layout: layouts/base.njk
title: My Other Sites
description: Articles from Text Lab, Variable Fonts, and Text Effects
permalink: /my-other-sites/
---
<section class="page-header-list-page">
  <h1 class="page-heading">My Other Sites</h1>
  <p class="page-heading-subtitle-list-page">Articles from Text Lab, Variable Fonts &amp; Text Effects</p>

  <div class="tag-group">
    <details class="tag-details">
      <summary>Tags</summary>
      <ul class="tag-list">
        <li class="tag-list-item"><a href="https://textlab.dev">Text Lab</a></li>
        <li class="tag-list-item"><a href="https://variablefonts.dev">Variable Fonts</a></li>
        <li class="tag-list-item"><a href="https://texteffects.dev">Text Effects</a></li>
      </ul>
    </details>
  </div>
</section>

<section class="section section-border">
  {% set externalPlaceholders = externalFeeds | assignPlaceholders %}
  <ul class="article-list external-list">
    {% for item in externalFeeds %}
    <li class="article-list-item external-item">
      <a href="{{ item.url }}" target="_blank" rel="noopener" aria-hidden="true" tabindex="-1">
        <img class="card-img" src="{{ item.image if item.image else externalPlaceholders[loop.index0] }}" alt="" width="440" height="280" />
      </a>
      <div class="card-content">
        <p class="card-meta">
          <a href="{{ item.sourceUrl }}" class="source-link">{{ item.source }}</a>
          {% if item.date %} &mdash; <time datetime="{{ item.date }}">{{ item.date | dateFromString }}</time>{% endif %}
        </p>
        <h3 class="card-heading">
          <a href="{{ item.url }}" class="card-link" target="_blank" rel="noopener">{{ item.title }}<span class="sr-only"> (opens in new tab)</span></a>
        </h3>
        {% if item.summary %}<p class="card-summary">{{ item.summary | striptags | truncate(160) }}</p>{% endif %}
      </div>
    </li>
    {% endfor %}
  </ul>
</section>
