---
layout: layouts/base.njk
title: Articles
description: All articles about frontend, type, and web things
permalink: /articles/
---
<section class="page-header">
  <h1 class="page-heading">Articles</h1>
  <p class="page-heading-subtitle">Frontend, type experiments, and web things</p>
</section>

<section class="section section-border">
  {% if collections.articles.length > 0 %}
  <ul class="article-list">
    {% for post in collections.articles %}
    <li class="article-list-item">
      {% if post.data.card and post.data.card.cardImage %}
      <a href="{{ post.url }}">
        <img class="card-img" src="{{ post.data.card.cardImage }}" alt="{{ post.data.card.cardAlt or post.data.title }}" width="440" height="280" />
      </a>
      {% else %}
      <a href="{{ post.url }}">
        <img class="card-img" src="/assets/images/placeholder-card.svg" alt="" width="440" height="280" />
      </a>
      {% endif %}
      <div class="card-content">
        <p class="card-meta">{{ post.date | readableDate }}</p>
        <h3 class="card-heading">
          <a href="{{ post.url }}" class="card-link">{{ post.data.title }}</a>
        </h3>
        {% if post.data.summary %}<p class="card-summary">{{ post.data.summary }}</p>{% endif %}
      </div>
    </li>
    {% endfor %}
  </ul>
  {% else %}
  <p>No articles yet — check back soon.</p>
  {% endif %}
</section>
