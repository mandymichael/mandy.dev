---
layout: layouts/base.njk
---
<article>
  <header class="post-header{% if not (card and card.cardImage and card.cardImage != '/assets/images/placeholder-hero.svg') %} post-header--no-image{% endif %}">

    <div class="post-meta-bar">
      <a href="/articles/" class="post-back-link">&larr; All Articles</a>
      {% if tags %}
      <ul class="post-meta-tags">
        {% for tag in tags %}
          {% if tag != "post" and tag != "article" and tag != "featured" %}
          <li class="post-meta-tag"><a href="/tags/{{ tag }}">{{ tag }}</a></li>
          {% endif %}
        {% endfor %}
      </ul>
      {% endif %}
      {% if date %}<time class="post-meta-date" datetime="{{ date | dateIso }}">{{ date | readableDate }}</time>{% endif %}
    </div>

    <h1 class="post-title">{{ title }}</h1>
    {% if summary %}<p class="post-summary">{{ summary }}</p>{% endif %}

    {% if card and card.cardImage and card.cardImage != '/assets/images/placeholder-hero.svg' %}
    <figure class="post-figure">
      <img src="{{ card.cardImage }}" alt="{{ card.cardAlt if card.cardAlt else title }}" class="post-hero-image" />
      {% if featureFont %}
      <figcaption class="post-figcaption">
        {{ featureFont.font }} by {{ featureFont.author }}{% if featureFont.publisher %}, {{ featureFont.publisher }}{% endif %}
      </figcaption>
      {% elif card.cardAlt %}
      <figcaption class="post-figcaption">{{ card.cardAlt }}</figcaption>
      {% endif %}
    </figure>
    {% endif %}

  </header>

  <div class="post-content PostContent">
    {{ content | safe }}
  </div>
</article>
